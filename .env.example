# SQLCraft — Environment Configuration
# Copy to .env and fill in values for your local setup.
# Never commit .env — it's in .gitignore.

# ── MySQL 8.4 ────────────────────────────────────────────────────────────────
SQLCRAFT_MYSQL_HOST=127.0.0.1
SQLCRAFT_MYSQL_PORT=13306
SQLCRAFT_MYSQL_DB=sqlcraft_test
SQLCRAFT_MYSQL_USER=sqlcraft
SQLCRAFT_MYSQL_PASS=secret

# ── MariaDB 11.4 ─────────────────────────────────────────────────────────────
SQLCRAFT_MARIADB_HOST=127.0.0.1
SQLCRAFT_MARIADB_PORT=13307
SQLCRAFT_MARIADB_DB=sqlcraft_test
SQLCRAFT_MARIADB_USER=sqlcraft
SQLCRAFT_MARIADB_PASS=secret

# ── PostgreSQL 17 ────────────────────────────────────────────────────────────
SQLCRAFT_PGSQL_HOST=127.0.0.1
SQLCRAFT_PGSQL_PORT=15432
SQLCRAFT_PGSQL_DB=sqlcraft_test
SQLCRAFT_PGSQL_USER=sqlcraft
SQLCRAFT_PGSQL_PASS=secret

# ── SQL Server 2022 ──────────────────────────────────────────────────────────
SQLCRAFT_MSSQL_HOST=127.0.0.1
SQLCRAFT_MSSQL_PORT=11433
SQLCRAFT_MSSQL_DB=sqlcraft_test
SQLCRAFT_MSSQL_USER=sa
SQLCRAFT_MSSQL_PASS=SQLcraft_Test1!

# ── Oracle XE 21c (optional — docker compose --profile oracle) ───────────────
SQLCRAFT_ORACLE_HOST=127.0.0.1
SQLCRAFT_ORACLE_PORT=11521
SQLCRAFT_ORACLE_SERVICE=XEPDB1
SQLCRAFT_ORACLE_USER=sqlcraft
SQLCRAFT_ORACLE_PASS=secret

# ── SQLite (no host/port — :memory: or file path) ────────────────────────────
# Leave empty to use :memory: (default for unit/integration tests).
# Set to an absolute path for file-backed tests, e.g. /tmp/sqlcraft_test.db
SQLCRAFT_SQLITE_PATH=

# ── Test behaviour ───────────────────────────────────────────────────────────
# Engines to run integration/contract tests against (comma-separated).
# Recognised values: mysql, mariadb, pgsql, mssql, oracle, sqlite
# Default (empty) = sqlite only (fast, no Docker needed).
SQLCRAFT_TEST_ENGINES=sqlite

# Set to 1 to enable verbose PDO error output during tests.
SQLCRAFT_TEST_DEBUG=0
